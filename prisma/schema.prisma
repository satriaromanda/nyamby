// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum DisputeStatus {
  open
  investigating
  resolved
}

enum DisputeReason {
  ghosting
  rejected_work
  low_quality
  cancellation
}

enum Role {
  talent
  client
}

enum TalentCategory {
  web_dev
  graphic_designer
}

enum Availability {
  available
  busy
  unavailable
}

enum SkillLevel {
  beginner
  intermediate
  expert
}

enum JobStatus {
  active
  matched
  in_progress
  submitted_for_review
  revision_requested
  completed
  cancelled
}

enum MatchRecommendation {
  highly_recommended
  recommended
  not_recommended
}

enum MatchStatus {
  recommended
  applied
  offered
  accepted
  rejected
}

enum EscrowStatus {
  held
  released
  refunded
}

enum AiAnalysisStatus {
  pending
  processing
  completed
  failed
}

// ─── Models ─────────────────────────────────────────────────────────────────

model User {
  id                  String   @id @default(uuid())
  email               String   @unique
  passwordHash        String   @map("password_hash")
  role                Role
  fullName            String   @map("full_name")
  avatarUrl           String?  @map("avatar_url")
  onboardingComplete  Boolean  @default(false) @map("onboarding_complete")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  // Relations
  talentProfile   TalentProfile?
  clientProfile   ClientProfile?
  postedJobs      Job[]               @relation("ClientJobs")
  escrowsAsClient EscrowTransaction[] @relation("EscrowClient")
  escrowsAsTalent EscrowTransaction[] @relation("EscrowTalent")
  notifications   Notification[]
  initiatedDisputes DisputeTicket[]   @relation("DisputeInitiator")

  @@map("users")
}

model TalentProfile {
  id               String         @id @default(uuid())
  userId           String         @unique @map("user_id")
  bio              String?
  category         TalentCategory
  ratePerHour      Decimal?       @map("rate_per_hour") @db.Decimal(10, 2)
  ratePerProject   Decimal?       @map("rate_per_project") @db.Decimal(10, 2)
  availability     Availability   @default(available)
  location         String?
  portfolioUrl     String?        @map("portfolio_url")
  portfolioFile    String?        @map("portfolio_file")
  cvFile           String?        @map("cv_file")
  cvText           String?        @map("cv_text")
  portfolioContext String?        @map("portfolio_context")
  createdAt        DateTime       @default(now()) @map("created_at")

  // Relations
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  talentSkills     TalentSkill[]
  skillGapAnalyses SkillGapAnalysis[]
  jobMatches       JobMatch[]

  @@map("talent_profiles")
}

model ClientProfile {
  id              String   @id @default(uuid())
  userId          String   @unique @map("user_id")
  companyName     String?  @map("company_name")
  industry        String
  companySize     String?  @map("company_size")
  location        String
  description     String?
  websiteUrl      String?  @map("website_url")
  whatsappNumber  String?  @map("whatsapp_number")
  createdAt       DateTime @default(now()) @map("created_at")

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("client_profiles")
}

model Skill {
  id       String @id @default(uuid())
  name     String @unique
  category String

  // Relations
  talentSkills      TalentSkill[]
  jobRequiredSkills JobRequiredSkill[]

  @@map("skills")
}

model TalentSkill {
  id              String     @id @default(uuid())
  talentProfileId String     @map("talent_profile_id")
  skillId         String     @map("skill_id")
  level           SkillLevel

  // Relations
  talentProfile TalentProfile @relation(fields: [talentProfileId], references: [id], onDelete: Cascade)
  skill         Skill         @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([talentProfileId, skillId])
  @@map("talent_skills")
}

model SkillGapAnalysis {
  id                       String   @id @default(uuid())
  talentProfileId          String   @map("talent_profile_id")
  recommendedSkills        Json     @map("recommended_skills") @db.JsonB
  summary                  String
  profileCompletenessScore Int?     @map("profile_completeness_score")
  generatedAt              DateTime @default(now()) @map("generated_at")
  isLatest                 Boolean  @default(true) @map("is_latest")
  aiStatus                 AiAnalysisStatus @default(completed) @map("ai_status")

  // Relations
  talentProfile TalentProfile @relation(fields: [talentProfileId], references: [id], onDelete: Cascade)

  @@map("skill_gap_analyses")
}

model Job {
  id               String         @id @default(uuid())
  clientUserId     String         @map("client_user_id")
  title            String
  description      String
  category         TalentCategory
  budgetMin        Decimal?       @map("budget_min") @db.Decimal(12, 2)
  budgetMax        Decimal?       @map("budget_max") @db.Decimal(12, 2)
  deadline         DateTime?      @db.Date
  status           JobStatus      @default(active)
  submissionUrl    String?        @map("submission_url")
  submissionNotes  String?        @map("submission_notes")
  submittedAt      DateTime?      @map("submitted_at")
  createdAt        DateTime       @default(now()) @map("created_at")

  // Relations
  client            User               @relation("ClientJobs", fields: [clientUserId], references: [id])
  requiredSkills    JobRequiredSkill[]
  jobMatches        JobMatch[]
  escrowTransaction EscrowTransaction?
  disputeTickets    DisputeTicket[]

  @@map("jobs")
}

model JobRequiredSkill {
  id          String  @id @default(uuid())
  jobId       String  @map("job_id")
  skillId     String  @map("skill_id")
  isMandatory Boolean @default(true) @map("is_mandatory")

  // Relations
  job   Job   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([jobId, skillId])
  @@map("job_required_skills")
}

model JobMatch {
  id              String              @id @default(uuid())
  jobId           String              @map("job_id")
  talentProfileId String              @map("talent_profile_id")
  matchScore      Decimal             @map("match_score") @db.Decimal(5, 2)
  strengths       Json                @db.JsonB
  gaps            Json                @db.JsonB
  reasoning       String
  portfolioEvidence String?           @map("portfolio_evidence")
  recommendation  MatchRecommendation
  status          MatchStatus         @default(recommended)
  rejectionReason String?             @map("rejection_reason")
  aiStatus        AiAnalysisStatus    @default(completed) @map("ai_status")
  generatedAt     DateTime            @default(now()) @map("generated_at")

  // Relations
  job           Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  talentProfile TalentProfile @relation(fields: [talentProfileId], references: [id], onDelete: Cascade)

  @@unique([jobId, talentProfileId])
  @@map("job_matches")
}

model EscrowTransaction {
  id           String       @id @default(uuid())
  jobId        String       @unique @map("job_id")
  clientUserId String       @map("client_user_id")
  talentUserId String       @map("talent_user_id")
  amount       Decimal      @map("amount") @db.Decimal(12, 2)
  platformFee  Decimal      @map("platform_fee") @db.Decimal(12, 2)
  status       EscrowStatus @default(held)
  heldAt       DateTime?    @map("held_at")
  releasedAt   DateTime?    @map("released_at")

  // Relations
  job    Job  @relation(fields: [jobId], references: [id])
  client User @relation("EscrowClient", fields: [clientUserId], references: [id])
  talent User @relation("EscrowTalent", fields: [talentUserId], references: [id])
  disputeTickets DisputeTicket[]

  @@map("escrow_transactions")
}

model Notification {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  type         String
  message      String
  relatedJobId String?  @map("related_job_id")
  isRead       Boolean  @default(false) @map("is_read")
  metadata     Json     @default("{}") @db.JsonB
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model DisputeTicket {
  id              String        @id @default(uuid())
  jobId           String        @map("job_id")
  escrowId        String        @map("escrow_id")
  initiatorUserId String        @map("initiator_user_id")
  reason          DisputeReason
  description     String
  status          DisputeStatus @default(open)
  resolution      String?
  createdAt       DateTime      @default(now()) @map("created_at")

  // Relations
  job             Job               @relation(fields: [jobId], references: [id])
  escrow          EscrowTransaction @relation(fields: [escrowId], references: [id])
  initiator       User              @relation("DisputeInitiator", fields: [initiatorUserId], references: [id])

  @@map("dispute_tickets")
}
