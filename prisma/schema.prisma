// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum DisputeStatus {
  open
  investigating
  resolved
}

enum DisputeReason {
  ghosting
  rejected_work
  low_quality
  cancellation
  talent_resign
}

enum Role {
  talent
  client
  admin
}

enum TalentCategory {
  web_dev
  graphic_designer
}

enum Availability {
  available
  busy
  unavailable
}

enum SkillLevel {
  beginner
  intermediate
  expert
}

enum JobStatus {
  active
  matched
  in_progress
  submitted_for_review
  revision_requested
  disputed
  completed
  cancelled
}

enum MatchRecommendation {
  highly_recommended
  recommended
  not_recommended
}

enum MatchStatus {
  recommended
  applied
  offered
  accepted
  rejected
}

enum EscrowStatus {
  pending
  held
  released
  refunded
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  EXPIRED
}

enum PayoutStatus {
  PENDING
  SUCCESS
  FAILED
}

enum AiAnalysisStatus {
  pending
  processing
  completed
  failed
}

// ─── PRD v4.0 — Cross-Border Enums ─────────────────────────────────────────

enum ClientCountry {
  indonesia
  malaysia
  singapore
  other
}

enum Currency {
  IDR
  MYR
  SGD
  USD
}

// ─── Models ─────────────────────────────────────────────────────────────────

model User {
  id                  String   @id @default(uuid())
  email               String   @unique
  passwordHash        String   @map("password_hash")
  role                Role
  fullName            String   @map("full_name")
  avatarUrl           String?  @map("avatar_url")
  onboardingComplete  Boolean  @default(false) @map("onboarding_complete")
  isSuspended         Boolean  @default(false) @map("is_suspended")
  suspendReason       String?  @map("suspend_reason")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  // Relations
  talentProfile   TalentProfile?
  clientProfile   ClientProfile?
  postedJobs      Job[]               @relation("ClientJobs")
  escrowsAsClient EscrowTransaction[] @relation("EscrowClient")
  escrowsAsTalent EscrowTransaction[] @relation("EscrowTalent")
  notifications   Notification[]
  initiatedDisputes DisputeTicket[]   @relation("DisputeInitiator")
  givenRatings    TalentRating[]      @relation("ClientRatings")

  @@map("users")
}

model TalentProfile {
  id               String         @id @default(uuid())
  userId           String         @unique @map("user_id")
  slug             String?        @unique
  bio              String?
  category         TalentCategory
  ratePerHour      Decimal?       @map("rate_per_hour") @db.Decimal(10, 2)
  ratePerProject   Decimal?       @map("rate_per_project") @db.Decimal(10, 2)
  availability     Availability   @default(available)
  location         String?
  portfolioUrl     String?        @map("portfolio_url")
  portfolioFile    String?        @map("portfolio_file")
  cvFile           String?        @map("cv_file")
  cvText           String?        @map("cv_text")
  portfolioContext String?        @map("portfolio_context")
  bankCode         String?        @map("bank_code")
  bankAccount      String?        @map("bank_account")
  bankAccountName  String?        @map("bank_account_name")
  createdAt        DateTime       @default(now()) @map("created_at")

  // Relations
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  talentSkills       TalentSkill[]
  skillGapAnalyses   SkillGapAnalysis[]
  jobMatches         JobMatch[]
  ratings            TalentRating[]
  portfolioAnalyses  PortfolioAnalysis[]
  experiences        TalentExperience[]

  @@map("talent_profiles")
}

// PRD v5.3 §6.7 — Structured work experience / projects for AI matching quality
model TalentExperience {
  id              String        @id @default(uuid())
  talentProfileId String        @map("talent_profile_id")
  title           String
  company         String?
  description     String?
  techStack       String[]      @default([]) @map("tech_stack")
  startDate       DateTime?     @map("start_date") @db.Date
  endDate         DateTime?     @map("end_date") @db.Date
  url             String?
  createdAt       DateTime      @default(now()) @map("created_at")

  talentProfile TalentProfile @relation(fields: [talentProfileId], references: [id], onDelete: Cascade)

  @@map("talent_experiences")
}

model ClientProfile {
  id                  String         @id @default(uuid())
  userId              String         @unique @map("user_id")
  companyName         String?        @map("company_name")
  industry            String
  companySize         String?        @map("company_size")
  location            String
  description         String?
  websiteUrl          String?        @map("website_url")
  whatsappNumber      String?        @map("whatsapp_number")
  bankCode            String?        @map("bank_code")
  bankAccount         String?        @map("bank_account")
  bankAccountName     String?        @map("bank_account_name")
  // PRD v4.0 §2.1 — Cross-Border fields
  country             ClientCountry  @default(indonesia) @map("country")
  preferredCurrency   Currency       @default(IDR) @map("preferred_currency")
  businessVerifiedAt  DateTime?      @map("business_verified_at")
  businessEmailDomain String?        @map("business_email_domain")
  createdAt           DateTime       @default(now()) @map("created_at")

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("client_profiles")
}

model Skill {
  id       String @id @default(uuid())
  name     String @unique
  category String

  // Relations
  talentSkills      TalentSkill[]
  jobRequiredSkills JobRequiredSkill[]

  @@map("skills")
}

model TalentSkill {
  id              String     @id @default(uuid())
  talentProfileId String     @map("talent_profile_id")
  skillId         String     @map("skill_id")
  level           SkillLevel

  // Relations
  talentProfile TalentProfile @relation(fields: [talentProfileId], references: [id], onDelete: Cascade)
  skill         Skill         @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([talentProfileId, skillId])
  @@map("talent_skills")
}

model SkillGapAnalysis {
  id                       String   @id @default(uuid())
  talentProfileId          String   @map("talent_profile_id")
  recommendedSkills        Json     @map("recommended_skills") @db.JsonB
  summary                  String
  profileCompletenessScore Int?     @map("profile_completeness_score")
  generatedAt              DateTime @default(now()) @map("generated_at")
  isLatest                 Boolean  @default(true) @map("is_latest")
  aiStatus                 AiAnalysisStatus @default(completed) @map("ai_status")

  // Relations
  talentProfile TalentProfile @relation(fields: [talentProfileId], references: [id], onDelete: Cascade)

  @@map("skill_gap_analyses")
}

model Job {
  id               String         @id @default(uuid())
  clientUserId     String         @map("client_user_id")
  title            String
  description      String
  category         TalentCategory
  budgetMin        Decimal?       @map("budget_min") @db.Decimal(12, 2)
  budgetMax        Decimal?       @map("budget_max") @db.Decimal(12, 2)
  deadline         DateTime?      @db.Date
  status           JobStatus      @default(active)
  submissionUrl    String?        @map("submission_url")
  submissionNotes  String?        @map("submission_notes")
  submittedAt      DateTime?      @map("submitted_at")
  // PRD v5.3 §6.4 — Required experience level, feeds AI matching
  experienceLevel  SkillLevel?    @map("experience_level")
  // PRD v4.0 §2.2 — Currency display for cross-border clients
  displayCurrency  Currency       @default(IDR) @map("display_currency")
  fxRateAtPosting  Decimal?       @map("fx_rate_at_posting") @db.Decimal(12, 6)
  createdAt        DateTime       @default(now()) @map("created_at")

  // Relations
  client            User               @relation("ClientJobs", fields: [clientUserId], references: [id])
  requiredSkills    JobRequiredSkill[]
  jobMatches        JobMatch[]
  escrowTransaction EscrowTransaction?
  disputeTickets    DisputeTicket[]
  talentRating      TalentRating?

  @@map("jobs")
}

model JobRequiredSkill {
  id          String  @id @default(uuid())
  jobId       String  @map("job_id")
  skillId     String  @map("skill_id")
  isMandatory Boolean @default(true) @map("is_mandatory")

  // Relations
  job   Job   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([jobId, skillId])
  @@map("job_required_skills")
}

model JobMatch {
  id              String              @id @default(uuid())
  jobId           String              @map("job_id")
  talentProfileId String              @map("talent_profile_id")
  matchScore      Decimal             @map("match_score") @db.Decimal(5, 2)
  strengths       Json                @db.JsonB
  gaps            Json                @db.JsonB
  reasoning       String
  portfolioEvidence String?           @map("portfolio_evidence")
  recommendation  MatchRecommendation
  status          MatchStatus         @default(recommended)
  rejectionReason String?             @map("rejection_reason")
  aiStatus        AiAnalysisStatus    @default(completed) @map("ai_status")
  generatedAt     DateTime            @default(now()) @map("generated_at")

  // Relations
  job           Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  talentProfile TalentProfile @relation(fields: [talentProfileId], references: [id], onDelete: Cascade)

  @@unique([jobId, talentProfileId])
  @@map("job_matches")
}

model EscrowTransaction {
  id           String       @id @default(uuid())
  jobId        String       @unique @map("job_id")
  clientUserId String       @map("client_user_id")
  talentUserId String       @map("talent_user_id")
  amount       Decimal      @map("amount") @db.Decimal(12, 2)
  platformFee  Decimal      @map("platform_fee") @db.Decimal(12, 2)
  status       EscrowStatus @default(held)
  heldAt       DateTime?    @map("held_at")
  releasedAt   DateTime?    @map("released_at")

  // Relations
  job    Job  @relation(fields: [jobId], references: [id])
  client User @relation("EscrowClient", fields: [clientUserId], references: [id])
  talent User @relation("EscrowTalent", fields: [talentUserId], references: [id])
  disputeTickets DisputeTicket[]
  payment Payment?
  payouts Payout[]

  @@map("escrow_transactions")
}

model Notification {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  type         String
  message      String
  relatedJobId String?  @map("related_job_id")
  isRead       Boolean  @default(false) @map("is_read")
  metadata     Json     @default("{}") @db.JsonB
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model DisputeTicket {
  id                String        @id @default(uuid())
  jobId             String        @map("job_id")
  escrowId          String        @map("escrow_id")
  initiatorUserId   String        @map("initiator_user_id")
  reason            DisputeReason
  description       String
  status            DisputeStatus @default(open)
  resolution        String?
  progressPct       Int?          @map("progress_pct")
  talentAmount      Decimal?      @map("talent_amount") @db.Decimal(12, 2)
  clientRefundAmount Decimal?     @map("client_refund_amount") @db.Decimal(12, 2)
  resolvedAt        DateTime?     @map("resolved_at")
  resolvedByUserId  String?       @map("resolved_by_user_id")
  createdAt         DateTime      @default(now()) @map("created_at")

  // Relations
  job             Job               @relation(fields: [jobId], references: [id])
  escrow          EscrowTransaction @relation(fields: [escrowId], references: [id])
  initiator       User              @relation("DisputeInitiator", fields: [initiatorUserId], references: [id])

  @@map("dispute_tickets")
}

model Payment {
  id               String         @id @default(uuid())
  escrowId         String         @unique @map("escrow_id")
  xenithPayinId    String         @unique @map("xenith_payin_id")
  referenceCode    String         @unique @map("reference_code")
  customerReference String        @map("customer_reference")
  amount           Decimal        @db.Decimal(12, 2)
  paymentCode      String?        @map("payment_code")
  paymentCodeType  String?        @map("payment_code_type")
  status           PaymentStatus  @default(PENDING)
  redirectUrl      String?        @map("redirect_url")
  // PRD v4.0 §2.3 — Cross-border payment tracking
  originCountry    ClientCountry? @map("origin_country")
  originCurrency   Currency?      @map("origin_currency")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  // Relations
  escrowTransaction EscrowTransaction @relation(fields: [escrowId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Payout {
  id                   String       @id @default(uuid())
  escrowId             String       @map("escrow_id")
  xenithPayoutId       String       @unique @map("xenith_payout_id")
  referenceCode        String       @unique @map("reference_code")
  customerReference    String       @map("customer_reference")
  payoutType           String       @default("talent") @map("payout_type") // "talent" or "client_refund"
  amount               Decimal      @db.Decimal(12, 2)
  destinationAccount   String       @map("destination_account")
  destinationChannel   String       @map("destination_channel")
  status               PayoutStatus @default(PENDING)
  createdAt            DateTime     @default(now()) @map("created_at")
  updatedAt            DateTime     @updatedAt @map("updated_at")

  // Relations
  escrowTransaction EscrowTransaction @relation(fields: [escrowId], references: [id], onDelete: Cascade)

  @@map("payouts")
}

// ─── PRD v3.0 — New Models ──────────────────────────────────────────────────

model TalentRating {
  id              String   @id @default(uuid())
  jobId           String   @unique @map("job_id")
  talentProfileId String   @map("talent_profile_id")
  clientUserId    String   @map("client_user_id")
  score           Int      // 1–5 bintang
  comment         String?  // opsional, maks 500 char
  createdAt       DateTime @default(now()) @map("created_at")

  // Relations
  job           Job           @relation(fields: [jobId], references: [id])
  talentProfile TalentProfile @relation(fields: [talentProfileId], references: [id])
  client        User          @relation("ClientRatings", fields: [clientUserId], references: [id])

  @@map("talent_ratings")
}

model PortfolioAnalysis {
  id              String   @id @default(uuid())
  talentProfileId String   @map("talent_profile_id")
  overallScore    Int      @map("overall_score")
  dimensions      Json     @db.JsonB
  strengths       Json     @db.JsonB
  improvements    Json     @db.JsonB
  summary         String
  isLatest        Boolean  @default(true) @map("is_latest")
  generatedAt     DateTime @default(now()) @map("generated_at")

  // Relations
  talentProfile TalentProfile @relation(fields: [talentProfileId], references: [id], onDelete: Cascade)

  @@map("portfolio_analyses")
}
